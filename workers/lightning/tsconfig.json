{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "types": ["@cloudflare/workers-types"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    // node --experimental-strip-types exige extensión en los imports relativos
    "allowImportingTsExtensions": true
  },
  "include": ["src"],
  "exclude": ["src/vendor"]
}
